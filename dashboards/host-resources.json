{
  "uid": "helix-host-resources",
  "title": "Helix — Host & Container Resources",
  "description": "Container and host resource monitoring using cAdvisor and node_exporter. CPU, memory, disk I/O, filesystem fill, NTP offset, OOM events, and network errors.",
  "tags": ["helix", "host", "cadvisor", "node-exporter", "infra"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "pluginId": "prometheus", "label": "Datasource", "hide": 0, "refresh": 1 },
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(container_cpu_usage_seconds_total{job=\"cadvisor\", name!=\"\"}, name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    { "id": 1, "type": "row", "title": "CPU", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Container CPU Usage",
      "description": "CPU cores consumed per container. 1.0 = one core fully utilized.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{job=\"cadvisor\", name=~\"$container\"}[5m])", "legendFormat": "{{name}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Host CPU Utilization",
      "description": "Total CPU usage on the host. 1.0 = 100%.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\"}[5m]))", "legendFormat": "{{instance}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    { "id": 4, "type": "row", "title": "Memory", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 } },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Container Memory (Working Set)",
      "description": "Working set bytes per container. Does not include cache. OOM kill triggers at the limit.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "container_memory_working_set_bytes{job=\"cadvisor\", name=~\"$container\"}", "legendFormat": "{{name}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Host Memory Usage",
      "description": "Host available vs used memory.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\"}", "legendFormat": "used / {{instance}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"}", "legendFormat": "total / {{instance}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    { "id": 7, "type": "row", "title": "Disk", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 } },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Disk I/O Rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{job=\"node-exporter\"}[5m])", "legendFormat": "read / {{device}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "rate(node_disk_written_bytes_total{job=\"node-exporter\"}[5m])", "legendFormat": "write / {{device}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Filesystem Usage",
      "description": "Percentage of filesystem used. Red threshold at 90%.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.75 }, { "color": "red", "value": 0.90 }] }
        }
      },
      "targets": [
        { "expr": "1 - (node_filesystem_avail_bytes{job=\"node-exporter\", fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"node-exporter\", fstype!~\"tmpfs|overlay\"})", "legendFormat": "{{mountpoint}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    { "id": 10, "type": "row", "title": "Network & Clock", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 } },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Container Network I/O",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(container_network_receive_bytes_total{job=\"cadvisor\", name=~\"$container\"}[5m])", "legendFormat": "rx / {{name}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "rate(container_network_transmit_bytes_total{job=\"cadvisor\", name=~\"$container\"}[5m])", "legendFormat": "tx / {{name}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "NTP Clock Offset",
      "description": "System clock offset from NTP. Values above ±500ms affect attestation timing. Critical above ±2s.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      },
      "targets": [
        { "expr": "node_timex_offset_seconds{job=\"node-exporter\"}", "legendFormat": "{{instance}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    }
  ]
}
