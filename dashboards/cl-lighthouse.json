{
  "uid": "helix-cl-lighthouse",
  "title": "Helix — Lighthouse (CL)",
  "description": "Deep-dive dashboard for Lighthouse beacon node: head slot, finality, attestation gossip, block import time, libp2p P2P health, and Rust tokio runtime.",
  "tags": ["helix", "lighthouse", "cl", "consensus"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "participant",
        "type": "query",
        "label": "Participant",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(beacon_head_slot{job=\"ethereum-cl-lighthouse\"}, participant)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Chain Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Head Slot",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        { "expr": "beacon_head_slot{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Slot Lag",
      "description": "Slots behind the current expected slot. 0 = healthy.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [
        { "expr": "helix:cl:lighthouse:slot_lag{participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Finalized Epoch",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        { "expr": "beacon_finalized_epoch{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Finality Lag (Epochs)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [
        { "expr": "helix:cl:lighthouse:finality_lag{participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "P2P Peers",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 10 }] }
        }
      },
      "targets": [
        { "expr": "beacon_peer_connected_count{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "RSS Memory",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Head Slot & Finalized Epoch",
      "description": "Progression of head slot and finalized epoch over time. A gap between them indicates a finality stall.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "beacon_head_slot{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}", "legendFormat": "head slot / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "beacon_finalized_epoch{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"} * 32", "legendFormat": "finalized (in slots) / p{{participant}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Attestation & Block Processing",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Attestation Processing Rate",
      "description": "Attestations processed per second. A drop here may mean gossip backpressure.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(beacon_attestation_processing_requests_total{job=\"ethereum-cl-lighthouse\", result=\"processed\", participant=~\"$participant\"}[5m])", "legendFormat": "processed / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "rate(beacon_attestation_processing_requests_total{job=\"ethereum-cl-lighthouse\", result=\"Err\", participant=~\"$participant\"}[5m])", "legendFormat": "errors / p{{participant}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Block Import Latency (p50/p95/p99)",
      "description": "Time to import a new beacon block. High p99 may indicate slow EL or heavy state transitions.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(beacon_block_processing_seconds_bucket{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}[5m]))", "legendFormat": "p50 / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "histogram_quantile(0.95, rate(beacon_block_processing_seconds_bucket{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}[5m]))", "legendFormat": "p95 / p{{participant}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "histogram_quantile(0.99, rate(beacon_block_processing_seconds_bucket{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}[5m]))", "legendFormat": "p99 / p{{participant}}", "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "Gossip",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Gossip Received by Topic",
      "description": "Messages received per topic per second. Attestation topics are highest volume.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(beacon_gossip_received_total{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}[5m])", "legendFormat": "{{topic}} / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "libp2p Bandwidth",
      "description": "Total bytes sent and received over libp2p per second.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(beacon_libp2p_inbound_bytes_total{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}[5m])", "legendFormat": "inbound / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "rate(beacon_libp2p_outbound_bytes_total{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}[5m])", "legendFormat": "outbound / p{{participant}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "P2P Peers",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Peer Count",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 10 }] },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      },
      "targets": [
        { "expr": "beacon_peer_connected_count{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}", "legendFormat": "connected / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Process CPU & Memory",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 29 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"ethereum-cl-lighthouse\", participant=~\"$participant\"}", "legendFormat": "RSS / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    }
  ]
}
