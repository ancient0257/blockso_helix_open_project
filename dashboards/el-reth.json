{
  "uid": "helix-el-reth",
  "title": "Helix — Reth (EL)",
  "description": "Deep-dive dashboard for Reth execution client: MDBX database metrics, sync pipeline stages, Engine API performance, P2P sessions, and pruning progress.",
  "tags": ["helix", "reth", "el", "execution"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "pluginId": "prometheus", "label": "Datasource", "hide": 0, "refresh": 1 },
      { "name": "participant", "type": "query", "label": "Participant", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(reth_network_connected_peers, participant)", "refresh": 2, "includeAll": true, "allValue": ".*", "multi": true, "sort": 1 }
    ]
  },
  "panels": [
    { "id": 1, "type": "row", "title": "Sync & Chain", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    { "id": 2, "type": "stat", "title": "Canonical Chain Height", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 }, "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }, "fieldConfig": { "defaults": { "unit": "none" } }, "targets": [{ "expr": "reth_blockchain_tree_canonical_chain_height{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }] },
    { "id": 3, "type": "stat", "title": "P2P Peers", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 }, "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }, "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 10 }] } } }, "targets": [{ "expr": "reth_network_connected_peers{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }] },
    { "id": 4, "type": "stat", "title": "MDBX Freelist Pages", "description": "Free pages in the MDBX database. Very low values may indicate a fragmentation issue.", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 }, "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }, "fieldConfig": { "defaults": { "unit": "none" } }, "targets": [{ "expr": "reth_db_freelist{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }] },
    { "id": 5, "type": "stat", "title": "RSS Memory", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 }, "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }, "fieldConfig": { "defaults": { "unit": "bytes" } }, "targets": [{ "expr": "process_resident_memory_bytes{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }] },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Canonical Chain Height",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } } },
      "targets": [{ "expr": "reth_blockchain_tree_canonical_chain_height{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "P2P Sessions (Active/Pending)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "reth_network_connected_peers{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "connected / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "reth_network_pending_session_handshakes{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "pending handshake / p{{participant}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    { "id": 8, "type": "row", "title": "Engine API Latency", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 } },
    {
      "id": 9,
      "type": "timeseries",
      "title": "engine_newPayload Latency (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(reth_engine_rpc_response_time_seconds_bucket{job=\"ethereum-el-reth\", method=~\"engine_newPayloadV.*\", participant=~\"$participant\"}[5m]))", "legendFormat": "p50 / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "histogram_quantile(0.95, rate(reth_engine_rpc_response_time_seconds_bucket{job=\"ethereum-el-reth\", method=~\"engine_newPayloadV.*\", participant=~\"$participant\"}[5m]))", "legendFormat": "p95 / p{{participant}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "histogram_quantile(0.99, rate(reth_engine_rpc_response_time_seconds_bucket{job=\"ethereum-el-reth\", method=~\"engine_newPayloadV.*\", participant=~\"$participant\"}[5m]))", "legendFormat": "p99 / p{{participant}}", "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "engine_forkchoiceUpdated Latency (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(reth_engine_rpc_response_time_seconds_bucket{job=\"ethereum-el-reth\", method=\"engine_forkchoiceUpdatedV3\", participant=~\"$participant\"}[5m]))", "legendFormat": "p50 / p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "histogram_quantile(0.99, rate(reth_engine_rpc_response_time_seconds_bucket{job=\"ethereum-el-reth\", method=\"engine_forkchoiceUpdatedV3\", participant=~\"$participant\"}[5m]))", "legendFormat": "p99 / p{{participant}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    { "id": 11, "type": "row", "title": "MDBX Database", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 } },
    {
      "id": 12,
      "type": "timeseries",
      "title": "MDBX Freelist Pages",
      "description": "Free database pages available for reuse. A declining trend may indicate write-heavy workload.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } } },
      "targets": [{ "expr": "reth_db_freelist{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Process Memory (RSS)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "targets": [{ "expr": "process_resident_memory_bytes{job=\"ethereum-el-reth\", participant=~\"$participant\"}", "legendFormat": "p{{participant}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }]
    }
  ]
}
