{
  "uid": "helix-overview",
  "title": "Helix — Devnet Overview",
  "description": "Single-pane-of-glass view across all Ethereum devnet participants. Answers: is anything broken, and where?",
  "tags": ["helix", "overview", "devnet"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "participant",
        "type": "query",
        "label": "Participant",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(beacon_head_slot, participant)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "hide": 0,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Execution Layer — Sync Status",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "EL Head Block",
      "description": "Latest canonical head block across all EL participants.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "none",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max by (client, participant) (chain_head_block{client_type=\"el\", participant=~\"$participant\"})",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "EL Sync Status",
      "description": "Sync status from ethereum-metrics-exporter (0 = synced, 1 = syncing).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "Synced", "color": "green" }, "1": { "text": "Syncing", "color": "yellow" } }, "type": "value" }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "ethereum_sync_status{participant=~\"$participant\"}",
          "legendFormat": "p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "EL Block Processing Rate",
      "description": "Blocks processed per second across all EL clients.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(chain_head_block{client_type=\"el\", participant=~\"$participant\"}[5m])",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Consensus Layer — Head & Finality",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "CL Head Slot",
      "description": "Current head slot for all CL participants.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "beacon_head_slot{client_type=\"cl\", participant=~\"$participant\"}",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "CL Slot Lag",
      "description": "How many slots behind the current expected slot each CL participant is. 0 = healthy.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "floor(time() / 12) - beacon_head_slot{client_type=\"cl\", participant=~\"$participant\"}",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Finalized Epoch",
      "description": "Latest finalized epoch per CL participant.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 10 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "beacon_finalized_epoch{client_type=\"cl\", participant=~\"$participant\"}",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Finality Lag (Epochs)",
      "description": "How many epochs behind finality is. >4 epochs for 10+ minutes indicates a finality stall.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "floor(time() / 384) - beacon_finalized_epoch{client_type=\"cl\", participant=~\"$participant\"}",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Head Slot Over Time",
      "description": "Canonical head slot progression for all CL participants. Diverging lines indicate a fork.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "beacon_head_slot{client_type=\"cl\", participant=~\"$participant\"}",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "P2P — Peer Counts",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "EL Peer Count",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 23 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": { "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 10 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "p2p_peers{client_type=\"el\", participant=~\"$participant\"}",
          "legendFormat": "{{client}} / p{{participant}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "reth_network_connected_peers{client_type=\"el\", participant=~\"$participant\"}",
          "legendFormat": "reth / p{{participant}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "CL Peer Count",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 23 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 10 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "beacon_peer_connected_count{participant=~\"$participant\"}",
          "legendFormat": "lighthouse / p{{participant}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "p2p_peer_count{state=\"Connected\", participant=~\"$participant\"}",
          "legendFormat": "prysm / p{{participant}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "libp2p_peers{participant=~\"$participant\"}",
          "legendFormat": "{{job}} / p{{participant}}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nbc_peers{participant=~\"$participant\"}",
          "legendFormat": "nimbus / p{{participant}}",
          "refId": "D"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Host Resources",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Container CPU Usage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 30 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(container_cpu_usage_seconds_total{job=\"cadvisor\", name=~\".*(geth|reth|lighthouse|prysm|teku|nimbus|lodestar|erigon|nethermind|besu).*\"}[5m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Container Memory Usage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 30 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "container_memory_working_set_bytes{job=\"cadvisor\", name=~\".*(geth|reth|lighthouse|prysm|teku|nimbus|lodestar|erigon|nethermind|besu).*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
